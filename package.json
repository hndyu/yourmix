{
	"name": "yourmix",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"dev:test": "wrangler dev --local --port 3000 -- next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
		"generate-types": "wrangler types",
		"type-check": "generate-types && tsc",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"db:generate": "drizzle-kit generate",
		"seed": "echo '⚠️  Please use seed:local or seed:remote instead' && exit 1",
		"seed:local": "tsx scripts/seed-worker.ts local",
		"seed:remote": "tsx scripts/seed-worker.ts remote",
		"start:ci": "npx wrangler pages dev .open-next --port 3000 --local"
	},
	"dependencies": {
		"@emotion/cache": "^11.14.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.0",
		"@google/genai": "^1.27.0",
		"@mui/icons-material": "^7.1.0",
		"@mui/material": "^7.1.0",
		"@mui/material-nextjs": "^7.1.0",
		"@opennextjs/cloudflare": "^1.14.0",
		"@testing-library/user-event": "^14.6.1",
		"better-auth-cloudflare": "^0.2.8",
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.5",
		"drizzle-orm": "^0.44.7",
		"next": "^15.5.7",
		"react": "^19.0.1",
		"react-dom": "^19.2.1",
		"uuid": "^13.0.0",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@cloudflare/workers-types": "^4.20251014.0",
		"@playwright/test": "^1.53.2",
		"@tailwindcss/postcss": "^4",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^20.19.23",
		"@types/react": "^19.2.6",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^10.0.0",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/ui": "^3.2.4",
		"jsdom": "^26.1.0",
		"schema-dts": "^1.1.5",
		"tailwindcss": "^4",
		"tsx": "^4.20.6",
		"typescript": "^5",
		"vite": "^7.2.2",
		"vitest": "^3.2.4",
		"wait-on": "^9.0.3",
		"wrangler": "^4.51.0"
	}
}
